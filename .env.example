OPENAI_API_KEY=replace-with-local-secret
JOZ_MODEL_PROVIDER=openai
JOZ_MODEL=gpt-4o-mini
# For a self-hosted decoder-only transformer served through vLLM/TGI:
# JOZ_MODEL_PROVIDER=self_hosted_transformer
# JOZ_TRANSFORMER_BASE_URL=http://127.0.0.1:8000/v1
# JOZ_TRANSFORMER_MODEL=your-local-model-id
# JOZ_TRANSFORMER_API_KEY=optional-local-gateway-key
SUPABASE_DB_URL=replace-with-local-database-url
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_JWT_SECRET=replace-with-supabase-jwt-secret-or-use-jwks
JOZ_REQUIRE_AUTH=false
JOZ_REQUIRE_DATABASE=false
